@page "/products"
@using DataEntities
@using Store.Services
@inject IConfiguration Configuration
@inject ProductService ProductService
@rendermode InteractiveServer
@attribute [StreamRendering(true)]

<PageTitle>Products</PageTitle>

<div class="products-header">
    <h1>Products</h1>
    <p>Here are some of our amazing outdoor products that you can purchase.</p>
</div>

@if (products == null)
{
    <div class="d-flex flex-column justify-content-center align-items-center py-5" style="min-height:200px;">
        <div class="spinner-border text-primary" role="status" style="width:3rem; height:3rem;">
            <span class="visually-hidden">Carregando...</span>
        </div>
        <p class="mt-3 mb-0 text-muted">Carregando produtos...</p>
    </div>
}
else if (products.Count == 0)
{
    <p class="text-muted">Nenhum produto disponível no momento.</p>
}
else
{
    <div class="products-grid">
        @foreach (var product in products)
        {
            <div class="product-card">
                <div class="product-image-container">
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@($"{imagePrefix}/{product.ImageUrl}")" alt="@product.Name" />
                    }
                    else
                    {
                        <div class="product-placeholder">
                            <span>Sem imagem</span>
                        </div>
                    }
                </div>

                <div class="product-info">
                    <h3 class="product-name">@product.Name</h3>

                    @if (!string.IsNullOrEmpty(product.Description))
                    {
                        <p class="product-description">@product.Description</p>
                    }

                    <div class="product-footer">
                        <span class="product-price">@product.Price.ToString("C")</span>
                        <button class="add-to-cart-btn">Buy Now</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Product>? products;
    private string imagePrefix = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        imagePrefix = Configuration["ImagePrefix"]!;
        products = await ProductService.GetProducts();
    }
}
